<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="CertificateInstallerForMSIX.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CertificateInstallerForMSIX"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    Title="Certificate Installer for MSIX - Ivirius Community"
    Width="540"
    Height="280"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    mc:Ignorable="d">
    <winuiex:WindowEx.SystemBackdrop>
        <MicaBackdrop />
    </winuiex:WindowEx.SystemBackdrop>
    <Grid>
        <StackPanel
            Margin="8,7"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Orientation="Horizontal"
            Spacing="6">
            <Image
                x:Name="TitleBarIcon"
                Width="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                x:FieldModifier="public"
                Source="/Assets/Certificate.ico" />
            <TextBlock
                x:Name="WindowTitle"
                x:FieldModifier="public"
                FontFamily="Segoe UI"
                FontSize="12"
                FontWeight="Normal"
                Text="Certificate Installer for MSIX - Ivirius Community"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel
            Margin="24,40"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Orientation="Vertical"
            Spacing="8">
            <InfoBar
                Title="In order to sideload some untrusted applications, you need to install a proper certificate. This utility allows you to do that in fewer steps than what windows provides by default."
                IsClosable="False"
                IsOpen="True" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PathBox" PlaceholderText="Certificate path" />
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Bottom"
                    Command="{x:Bind GetCertificateCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE838;" />
                        <TextBlock Text="Browse" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
        <Grid
            Padding="24"
            VerticalAlignment="Bottom"
            Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Button
                x:Name="Install"
                Width="160"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{x:Bind InstallCertificateCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE896;" />
                    <TextBlock Text="Install" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</winuiex:WindowEx>